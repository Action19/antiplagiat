# Server
PORT=5000
NODE_ENV=development

# Database (Render PostgreSQL URL)
DATABASE_URL=postgresql://user:password@host:5432/antiplagiat
DB_HOST=localhost
DB_PORT=5432
DB_NAME=antiplagiat
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Frontend URL (Netlify)
FRONTEND_URL=https://your-app-name.netlify.app

# HuggingFace API (AI Detection uchun - ixtiyoriy)
# https://huggingface.co/settings/tokens dan oling
HUGGINGFACE_API_KEY=your_huggingface_api_token
